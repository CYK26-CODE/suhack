# === Required ===
GROK_API_KEY=your_xai_api_key_here
GITHUB_TOKEN=your_github_personal_access_token_here
# TARGET_REPO_URL is optional — users enter this on the frontend dashboard
# TARGET_REPO_URL=https://github.com/your-org/your-repo

# === Optional ===
TARGET_BRANCH=main
RISK_THRESHOLD=0.7
MAX_HEAL_RETRIES=2
FILE_EXTENSIONS=.py
LLM_TEMPERATURE=0.2
LLM_MODEL=grok-3

# === Infrastructure ===
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
ANALYSIS_TIMEOUT_SECS=300
